{
  "name": "uniqa-conversion-coach-workspace",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "shared",
    "extension",
    "coach-api",
    "admin-portal"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run build --workspace @uniqa-conversion-coach/shared && npm run test --workspaces --if-present",
    "pipeline": "python uniqa_pipeline.py",
    "pipeline:local": "bash ./scripts/run_local_full_loop.sh",
    "db:up": "bash ./scripts/db-up.sh",
    "db:down": "bash ./scripts/db-down.sh",
    "db:reset": "bash ./scripts/db-reset.sh",
    "db:logs": "bash ./scripts/db-logs.sh",
    "db:migrate": "bash ./scripts/db-migrate.sh",
    "dev:coach-api": "node --env-file=.env node_modules/tsx/dist/cli.mjs watch coach-api/src/server.ts",
    "dev:admin": "npm run dev --workspace admin-portal",
    "build:extension": "npm run build --workspace extension",
    "pipeline:local": "bash ./scripts/run_local_training_pipeline.sh"
  }
}
