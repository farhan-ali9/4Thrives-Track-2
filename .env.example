# Copy this file to `.env` and fill in your keys.
# The Streamlit app auto-loads `.env` from the repo root on startup.

# Coach API + admin portal
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/conversion_coach
SESSION_SECRET=dev-session-secret
BOOTSTRAP_ADMIN_EMAIL=admin@uniqa.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-now
BOOTSTRAP_ADMIN_NAME=UNIQA Coach Admin

# Chrome extension build-time origins
VITE_COACH_API_ORIGIN=http://127.0.0.1:8787
# VITE_COACH_API_EXTRA_ORIGINS=https://your-app.ondigitalocean.app

# Featherless AI (default LLM provider) — get one at https://featherless.ai
FEATHERLESS_API_KEY=rc_your_key_here
VITE_FEATHERLESS_MODEL=MihaiPopa-1/Qwen-3-0.6B-Claude-4.7-Opus-Distilled
VITE_FEATHERLESS_MODEL_OPTIONS=MihaiPopa-1/Qwen-3-0.6B-Claude-4.7-Opus-Distilled

# Local simulation/training pipeline persona LLM.
# Uses the same Featherless key as the extension chat.
LLM_API_URL=https://api.featherless.ai/v1/chat/completions
LLM_MODEL=MihaiPopa-1/Qwen-3-0.6B-Claude-4.7-Opus-Distilled
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_S=30
EXTENSION_DIST=extension/dist
COACH_API_URL=http://127.0.0.1:8787
UNIQA_CALCULATOR_URL=https://www.uniqa.at/rechner/krankenversicherung/
RUNNER_MODE=validation
# Preferred: one persona run executes every persona/intention pair once.
# 3 personas x 4 intentions = 12 baseline sessions and 12 coach sessions.
PERSONA_RUNS=1
# Optional overrides if you want exact counts instead of full persona cycles.
# BASELINE_SESSIONS=12
# COACH_SESSIONS=12
# Legacy shorthand: sets both baseline and coach sessions when the wrapper is used.
# RUNNER_SESSIONS=12
RUNNER_DWELL_MULTIPLIER=2.2
RUNNER_MIN_THINK_MS=1800
RUNNER_MAX_THINK_MS=9000
PIPELINE_OUTPUT_ROOT=artifacts/local-training-pipeline/latest
EVALUATION_RUNNER_MODE=mock
EVALUATION_SESSIONS_PER_MODE=6

# Optional fallbacks (only one provider key is needed)
# GROQ_API_KEY=gsk_your_key_here
# LOVABLE_API_KEY=sk_your_key_here

# Optional overrides
# LLM_GATEWAY_URL=https://api.featherless.ai/v1/chat/completions
# LLM_DEFAULT_MODEL=MihaiPopa-1/Qwen-3-0.6B-Claude-4.7-Opus-Distilled

# Chrome extension chat model picker.
# VITE_FEATHERLESS_MODEL is one default model only.
# VITE_FEATHERLESS_MODEL_OPTIONS is a comma-separated list for the dropdown.
# VITE_FEATHERLESS_MODEL=MihaiPopa-1/Qwen-3-0.6B-Claude-4.7-Opus-Distilled
# VITE_FEATHERLESS_MODEL_OPTIONS=MihaiPopa-1/Qwen-3-0.6B-Claude-4.7-Opus-Distilled
#
# JSON array format also works:
# VITE_FEATHERLESS_MODEL_OPTIONS=["MihaiPopa-1/Qwen-3-0.6B-Claude-4.7-Opus-Distilled"]
