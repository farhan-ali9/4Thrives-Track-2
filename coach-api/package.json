{
  "name": "coach-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "postinstall": "prisma generate",
    "start": "prisma migrate deploy && node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.1",
    "@prisma/client": "^6.9.0",
    "@uniqa-conversion-coach/shared": "file:../shared",
    "fastify": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "prisma": "^6.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
