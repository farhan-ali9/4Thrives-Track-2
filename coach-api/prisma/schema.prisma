generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  passwordHash   String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  policyVersions PolicyVersion[] @relation("PolicyVersionCreator")
}

model PolicyVersion {
  id                          String          @id @default(cuid())
  version                     Int             @unique
  isActive                    Boolean         @default(false)
  policy                      Json
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  createdByAdminId            String?
  createdBy                   AdminUser?      @relation("PolicyVersionCreator", fields: [createdByAdminId], references: [id])
  restoredFromPolicyVersionId String?
  restoredFromPolicyVersion   PolicyVersion?  @relation("PolicyVersionRestore", fields: [restoredFromPolicyVersionId], references: [id])
  restores                    PolicyVersion[] @relation("PolicyVersionRestore")

  @@index([isActive])
}

model SessionTraceEvent {
  id             String   @id @default(cuid())
  schemaVersion  String   @default("v1")
  eventId        String   @unique
  sessionId      String
  ts             BigInt
  source         String
  stepId         String?
  eventType      String
  elementKey     String?
  rawValue       Json     @default("{}")
  derivedSignals Json     @default("{}")
  derivedContext Json     @default("{}")
  runnerMetadata Json     @default("{}")
  privacyLevel   String   @default("anonymous")
  createdAt      DateTime @default(now())

  @@index([sessionId])
  @@index([sessionId, ts])
}

model ModelInferenceResult {
  id                  String   @id @default(cuid())
  decisionId          String   @unique
  sessionId           String
  modelVersion        String   @default("rule_based_v1")
  experimentId        String?
  candidateSetVersion String?
  chosenActionId      String?
  rankedCandidates    Json     @default("[]")
  guardrailDecisions  Json     @default("[]")
  latencyMs           Int
  riskScore           Int
  createdAt           DateTime @default(now())

  @@index([sessionId])
}

model InterventionExposure {
  id            String   @id @default(cuid())
  exposureId    String   @unique
  sessionId     String
  decisionId    String
  actionId      String
  impressionTs  BigInt?
  dismissTs     BigInt?
  ctaTs         BigInt?
  renderSuccess Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([sessionId])
  @@index([decisionId])
}

model JourneyOutcome {
  id                String   @id @default(cuid())
  sessionId         String   @unique
  outcome           String
  terminalStepId    String?
  advisorRouted     Boolean  @default(false)
  converted         Boolean  @default(false)
  abandoned         Boolean  @default(false)
  endedAt           BigInt?
  finalTariff       String?
  finalVisiblePrice Float?
  priceDelta        Float?
  createdAt         DateTime @default(now())

  @@index([outcome])
}
