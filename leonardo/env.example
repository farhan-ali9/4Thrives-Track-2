# Copy to an environment file outside git secrets handling before submitting jobs.
# Required for live browser validation:
EXTENSION_DIST=/absolute/path/to/extension/dist
COACH_API_URL=http://127.0.0.1:8787
UNIQA_CALCULATOR_URL=https://www.uniqa.at/versicherung/gesundheit/private-krankenversicherung.html
RUNNER_OUTPUT_DIR=artifacts/browser-runs
RUNNER_EXECUTION_MODE=coach

# Metadata stamped into every trace:
PAGE_MAP_VERSION=live-uniqa-v1
EXTENSION_BUILD_ID=local
MODEL_VERSION_OR_POLICY=rule-based

# Local OpenAI-compatible LLM endpoint served on Leonardo:
LLM_API_URL=http://127.0.0.1:8000/v1/chat/completions
LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_S=30

# Optional: launch vLLM inside the same Slurm job before the runner starts.
# Example:
# VLLM_SERVE_CMD="python -m vllm.entrypoints.openai.api_server --model meta-llama/Meta-Llama-3.1-8B-Instruct --host 127.0.0.1 --port 8000"
VLLM_SERVE_CMD=
VLLM_BOOT_WAIT_S=20

# Batch settings:
RUNNER_MODE=validation
RUNNER_SESSIONS=12
RUNNER_SESSIONS_PER_MODE=6
EVALUATION_MODES=baseline,rule_based
EVALUATION_OUTPUT_ROOT=artifacts/evaluation-experiments/latest
EXPERIMENT_ID=leonardo-validation
USER_POLICY_DATASET=artifacts/datasets/user-policy.jsonl
ACTION_RANKING_DATASET=artifacts/datasets/coach-ranking.jsonl
USER_POLICY_MODEL=artifacts/training/user-policy.json
TRAINABLE_RANKER_MODEL=artifacts/training/frequency-ranker.json
