# Copy to an environment file outside git secrets handling before submitting jobs.
# Required for live browser validation:
EXTENSION_DIST=/absolute/path/to/extension/dist
COACH_API_URL=http://127.0.0.1:8787
UNIQA_CALCULATOR_URL=https://www.uniqa.at/versicherung/gesundheit/private-krankenversicherung.html
RUNNER_OUTPUT_DIR=artifacts/browser-runs

# Metadata stamped into every trace:
PAGE_MAP_VERSION=live-uniqa-v1
EXTENSION_BUILD_ID=local
MODEL_VERSION_OR_POLICY=rule-based

# Batch settings:
RUNNER_MODE=validation
RUNNER_SESSIONS=3
RUNNER_SESSIONS_PER_MODE=6
EVALUATION_MODES=baseline,rule_based
EVALUATION_OUTPUT_ROOT=artifacts/evaluation-experiments/latest
EXPERIMENT_ID=leonardo-validation
