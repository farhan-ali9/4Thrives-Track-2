[
  {
    "pageStepId": "s1_coverage_scope",
    "coachStepId": "s1_coverage_scope",
    "verified": true,
    "enabled": true,
    "match": {
      "requiredText": ["Wo möchten Sie abgesichert sein?", "Bei Arztbesuchen", "Im Krankenhaus"],
      "requiredSelectorsAll": ["[data-cy='nextStepButton']"],
      "requiredSelectorsAny": ["input[type='checkbox']"]
    },
    "selectors": {
      "stepAnchor": ["h1", "form", "body"],
      "primaryCta": ["[data-cy='nextStepButton']"],
      "backButton": ["[data-cy='backButton']"],
      "cancelTargets": ["[data-cy='backButton']"],
      "outOfScopePathChoices": ["input[type='checkbox']"]
    },
    "extractors": [
      { "key": "fieldCompletion", "kind": "fieldCompletion", "selectors": ["input[type='checkbox']"] },
      { "key": "validationErrorCount", "kind": "validationErrorCount" },
      { "key": "sessionDurationMs", "kind": "sessionTiming" }
    ],
    "injectionAnchor": "inline-top-of-step"
  },
  {
    "pageStepId": "s2_for_whom",
    "coachStepId": "s2_for_whom",
    "verified": true,
    "enabled": true,
    "match": {
      "requiredText": ["Wer soll versichert werden?", "Ich selbst", "Andere Personen"],
      "requiredSelectorsAll": ["[data-cy='insuredPartyPolicyHolder']", "[data-cy='insuredPartyOther']"]
    },
    "selectors": {
      "stepAnchor": ["h1", "form", "body"],
      "primaryCta": ["[data-cy='nextStepButton']"],
      "backButton": ["[data-cy='backButton']"],
      "cancelTargets": ["[data-cy='backButton']"],
      "outOfScopePathChoices": ["[data-cy='insuredPartyOther']"]
    },
    "extractors": [
      { "key": "fieldCompletion", "kind": "fieldCompletion", "selectors": ["input[type='radio']"] },
      { "key": "validationErrorCount", "kind": "validationErrorCount" },
      { "key": "sessionDurationMs", "kind": "sessionTiming" }
    ],
    "injectionAnchor": "inline-top-of-step"
  },
  {
    "pageStepId": "s3_quote_basics",
    "coachStepId": "s3_personal_data",
    "verified": true,
    "enabled": true,
    "match": {
      "requiredText": [
        "Um eine voraussichtliche individuelle Prämie für Sie zu berechnen, benötigen wir:",
        "Geburtsdatum",
        "Sozialversicherung"
      ],
      "requiredSelectorsAll": ["[data-cy='ur-select-field-button']", "[data-cy='nextStepButton']"]
    },
    "selectors": {
      "stepAnchor": ["h1", "form", "body"],
      "primaryCta": ["[data-cy='nextStepButton']"],
      "backButton": ["[data-cy='backButton']"],
      "cancelTargets": ["[data-cy='backButton']"]
    },
    "extractors": [
      { "key": "ageBand", "kind": "ageBandFromDate", "selectors": ["input[placeholder='TT.MM.JJJJ']"] },
      {
        "key": "socialInsuranceProviderCode",
        "kind": "socialInsuranceProvider",
        "selectors": ["[data-cy='ur-select-field-input']"]
      },
      {
        "key": "fieldCompletion",
        "kind": "fieldCompletion",
        "selectors": ["input[placeholder='TT.MM.JJJJ']", "[data-cy='ur-select-field-input']"]
      },
      { "key": "validationErrorCount", "kind": "validationErrorCount" },
      { "key": "sessionDurationMs", "kind": "sessionTiming" }
    ],
    "injectionAnchor": "inline-top-of-step"
  },
  {
    "pageStepId": "s4_initial_price",
    "coachStepId": "s4_initial_price",
    "verified": true,
    "enabled": true,
    "match": {
      "requiredText": ["Voraussichtliche Prämie", "Opt. Plus", "Premium"],
      "requiredSelectorsAll": [
        "[data-cy='selectionButton_0']",
        "[data-cy='selectionButton_1']",
        "[data-cy='selectionButton_2']",
        "[data-cy='selectionButton_3']"
      ]
    },
    "selectors": {
      "stepAnchor": ["table", "body"],
      "primaryCta": ["[data-cy='nextStepButton']"],
      "backButton": ["[data-cy='backButton']"],
      "cancelTargets": ["[data-cy='backButton']"],
      "priceTargets": ["table", "[data-cy='selectionButton_0']", "[data-cy='selectionButton_1']"],
      "priceText": ["table"],
      "outOfScopeTariffButtons": ["[aria-label='Wählen Opt. Plus']", "[aria-label='Wählen Premium']"]
    },
    "extractors": [
      { "key": "selectedTariff", "kind": "selectedTariff", "selectors": ["[aria-label^='Wählen ']"] },
      { "key": "visiblePrice", "kind": "visiblePrice", "selectors": ["table"] },
      { "key": "priceDelta", "kind": "priceDelta", "selectors": ["table"] },
      { "key": "validationErrorCount", "kind": "validationErrorCount" },
      { "key": "sessionDurationMs", "kind": "sessionTiming" }
    ],
    "injectionAnchor": "near-primary-cta"
  },
  {
    "pageStepId": "s5_add_ons",
    "coachStepId": "s5_add_ons",
    "verified": true,
    "enabled": true,
    "match": {
      "requiredText": ["Wünschen Sie Extra-Schutz bei Ihrer Privatarzt-Versicherung?", "Fit fühlen", "VitalPlan"],
      "requiredSelectorsAll": ["[data-cy='nextStepButton']"],
      "requiredSelectorsAny": ["input[type='checkbox']"]
    },
    "selectors": {
      "stepAnchor": ["body"],
      "primaryCta": ["[data-cy='nextStepButton']"],
      "backButton": ["[data-cy='backButton']"],
      "cancelTargets": ["[data-cy='backButton']"],
      "priceTargets": [],
      "priceText": ["body"],
      "addOnCheckboxes": ["input[type='checkbox']"]
    },
    "extractors": [
      { "key": "selectedAddOns", "kind": "selectedAddOns", "selectors": ["input[type='checkbox']"] },
      { "key": "visiblePrice", "kind": "visiblePrice", "selectors": ["body"] },
      { "key": "priceDelta", "kind": "priceDelta", "selectors": ["body"] },
      { "key": "fieldCompletion", "kind": "fieldCompletion", "selectors": ["input[type='checkbox']"] },
      { "key": "validationErrorCount", "kind": "validationErrorCount" },
      { "key": "sessionDurationMs", "kind": "sessionTiming" }
    ],
    "injectionAnchor": "near-primary-cta"
  },
  {
    "pageStepId": "s6_personal_medical_data",
    "coachStepId": "s6_health_questions",
    "verified": true,
    "enabled": true,
    "match": {
      "requiredText": ["Angaben zu Ihrer Person", "Sozialversicherungsnummer", "Medizinische Angaben"],
      "requiredSelectorsAll": ["[data-cy='nextStepButton']"]
    },
    "selectors": {
      "stepAnchor": ["body"],
      "primaryCta": ["[data-cy='nextStepButton']"],
      "backButton": ["[data-cy='backButton']"],
      "cancelTargets": ["[data-cy='backButton']"],
      "priceTargets": [],
      "priceText": ["body"]
    },
    "extractors": [
      { "key": "fieldCompletion", "kind": "fieldCompletion", "selectors": ["input", "textarea"] },
      { "key": "validationErrorCount", "kind": "validationErrorCount" },
      { "key": "visiblePrice", "kind": "visiblePrice", "selectors": ["body"] },
      { "key": "priceDelta", "kind": "priceDelta", "selectors": ["body"] },
      { "key": "sessionDurationMs", "kind": "sessionTiming" }
    ],
    "injectionAnchor": "inline-top-of-step"
  },
  {
    "pageStepId": "s7_final_price",
    "coachStepId": "s7_final_price",
    "verified": true,
    "enabled": true,
    "match": {
      "requiredText": [
        "Bisherige Versicherungen",
        "Sind Sie oder waren Sie in den letzten 7 Jahren privat krankenversichert?",
        "Wurden Anträge abgelehnt oder Verträge durch den Versicherer gekündigt?"
      ],
      "requiredSelectorsAll": [
        "[data-cy='insuranceInPast7Years']",
        "[data-cy='rejectedApplication']",
        "[data-cy='nextStepButton']"
      ]
    },
    "selectors": {
      "stepAnchor": ["body"],
      "primaryCta": ["[data-cy='nextStepButton']"],
      "backButton": ["[data-cy='backButton']"],
      "cancelTargets": ["[data-cy='backButton']"],
      "priceTargets": ["body"],
      "priceText": ["body"]
    },
    "extractors": [
      {
        "key": "fieldCompletion",
        "kind": "fieldCompletion",
        "selectors": [
          "[data-cy='insuranceInPast7Years'] input[type='radio']",
          "[data-cy='rejectedApplication'] input[type='radio']"
        ]
      },
      { "key": "visiblePrice", "kind": "visiblePrice", "selectors": ["body"] },
      { "key": "priceDelta", "kind": "priceDelta", "selectors": ["body"] },
      { "key": "validationErrorCount", "kind": "validationErrorCount" },
      { "key": "sessionDurationMs", "kind": "sessionTiming" }
    ],
    "injectionAnchor": "near-primary-cta"
  },
  {
    "pageStepId": "s8_confirm",
    "coachStepId": "s8_confirm",
    "verified": true,
    "enabled": true,
    "match": {
      "requiredText": [
        "Berateranfrage",
        "Wo soll die Beratung bevorzugt stattfinden?",
        "Online Videoberatung"
      ],
      "requiredSelectorsAll": [
        "[data-cy='consultationContact']",
        "[data-cy='nextStepButton']"
      ]
    },
    "selectors": {
      "stepAnchor": ["body"],
      "primaryCta": ["[data-cy='nextStepButton']"],
      "backButton": ["[data-cy='backButton']"],
      "cancelTargets": ["[data-cy='backButton']"]
    },
    "extractors": [
      {
        "key": "fieldCompletion",
        "kind": "fieldCompletion",
        "selectors": ["[data-cy='consultationContact'] input[type='radio']"]
      },
      { "key": "visiblePrice", "kind": "visiblePrice", "selectors": ["body"] },
      { "key": "priceDelta", "kind": "priceDelta", "selectors": ["body"] },
      { "key": "validationErrorCount", "kind": "validationErrorCount" },
      { "key": "sessionDurationMs", "kind": "sessionTiming" }
    ],
    "injectionAnchor": "bottom-toast"
  }
]
